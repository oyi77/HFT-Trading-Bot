# XAU/USD (Gold) Optimized Configuration
# Based on ahdu.mq5 / halah.mq5 profitable settings

# Trading Parameters - Optimized for Gold
SYMBOL=XAU/USD
LOTS=0.01
STOP_LOSS=1000
TAKE_PROFIT=0
TRAILING=500
TRAIL_START=800
X_DISTANCE=300
DIRECTION=0

# Risk Management - Conservative for Gold
MAX_DAILY_LOSS=50
MAX_DRAWDOWN=10

# Break Even - Lock in profits quickly
USE_BREAK_EVEN=true
BREAK_EVEN_PROFIT=400
BREAK_EVEN_OFFSET=50

# Session Filter (Important for Gold!)
USE_ASIA_SESSION=false
USE_LONDON_OPEN=true
USE_LONDON_PEAK=true
USE_NY_SESSION=true

# Exchange (for live trading)
EXCHANGE=exness

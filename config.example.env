# HFT Bot Configuration
# Copy to .env and fill in your keys

# Exchange API Keys (for CCXT exchanges like Binance, Bybit, OKX)
BINANCE_API_KEY=your_api_key_here
BINANCE_API_SECRET=your_api_secret_here

# Ostium (for decentralized perpetual trading)
PRIVATE_KEY=your_private_key_here
RPC_URL=https://arb1.arbitrum.io/rpc

# Bot Settings
SYMBOL=BTC/USDT
EXCHANGE=binance
MODE=paper  # backtest, paper, or live

# Trading Parameters
LOTS=0.1
STOP_LOSS=1500
TAKE_PROFIT=0
TRAILING=500
TRAIL_START=1000
X_DISTANCE=300
DIRECTION=0  # 0=BUY first, 1=SELL first

# Risk Management
DAILY_LOSS=true
MAX_DAILY_LOSS=100
DRAWDOWN=true
MAX_DRAWDOWN=20
BREAK_EVEN=true
BE_PROFIT=500
BE_OFFSET=10
